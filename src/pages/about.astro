---
import BaseLayout from '../layouts/BaseLayout.astro';
import LeadershipQuote from '../components/LeadershipQuote.astro';
import CTABand from '../components/CTABand.astro';

const principles = [
  {
    title: 'Equity as the starting point',
    body:
      'Every engagement starts with the question: who is being served well today, and who is not? Program design flows from there.',
    icon:
      '<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>',
  },
  {
    title: 'Research into practice',
    body:
      'We translate peer-reviewed research on biliteracy and second language acquisition into strategies teachers can use on Monday morning.',
    icon: '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
  },
  {
    title: 'Partners, not vendors',
    body:
      'We build long-term relationships with districts. Our work ends when your team no longer needs us — not when the contract runs out.',
    icon:
      '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  },
  {
    title: 'Families as architects',
    body:
      'Multilingual communities are built with families, not for them. Authentic engagement is baked into everything we help design.',
    icon: '<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
  },
];

const credentials = [
  { name: 'WIDA Consortium', url: 'https://wida.wisc.edu/', note: 'English learner standards & assessment' },
  { name: 'ACTFL', url: 'https://www.actfl.org/', note: 'American Council on the Teaching of Foreign Languages' },
  { name: 'CARLA', url: 'https://carla.umn.edu/', note: 'Center for Advanced Research on Language Acquisition' },
  { name: 'Center for Applied Linguistics', url: 'https://www.cal.org/', note: 'Dual language program design research' },
];
---

<BaseLayout
  title="About"
  description="Meet the team behind Immersion Education Partners. Milwaukee-rooted educational consultants helping districts build multilingual communities."
>
  <!-- Page header -->
  <section class="page-header section-padding">
    <div class="container">
      <div class="header-content reveal">
        <span class="overline">About</span>
        <h1>Educators first. Consultants second.</h1>
        <p class="lede">
          Immersion Education Partners was founded on a simple idea: the strongest multilingual
          programs are built by people who have stood in classrooms, wrestled with the tradeoffs,
          and stayed up late rewriting a unit plan. That's who we are, and that's how we work.
        </p>
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="section-padding mission">
    <div class="container">
      <div class="mission-layout">
        <div class="reveal">
          <span class="overline">Our Mission</span>
          <h2>Multilingualism is a form of educational justice</h2>
        </div>
        <div class="reveal" data-delay="100">
          <p>
            We believe that strong dual language and immersion programs aren't perks — they're a
            pathway to opportunity for every learner. When a district commits to multilingualism,
            it commits to honoring the linguistic and cultural wealth every child brings to school.
          </p>
          <p>
            Our work supports that commitment end to end: from the first community conversation
            through the tenth-year program audit. We bring research, experience, and a deep respect
            for the adults in the room — because sustainable change happens when teachers and
            leaders are trusted, supported, and equipped.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Leadership (anchor target for /#leadership and /about#leadership) -->
  <div id="leadership">
    <LeadershipQuote compact />
  </div>

  <!-- Kane's bio -->
  <section class="section-padding bio">
    <div class="container">
      <div class="bio-layout reveal">
        <h2>About Kane Neubauer</h2>
        <div class="bio-body">
          <p class="placeholder-note">
            <strong>[TODO]</strong> Replace with Kane's actual bio — 2 to 3 short paragraphs.
            Recommended structure:
          </p>
          <ol>
            <li>Roles, years in education, districts worked in.</li>
            <li>Specific areas of expertise (dual language, biliteracy, equity, PD design).</li>
            <li>Why this work matters to him personally.</li>
          </ol>

          <p class="placeholder-note" style="margin-top:2rem;">
            <strong>[TODO]</strong> Provide credentials, degrees, certifications, speaking
            engagements, and publications. Example format:
          </p>
          <ul class="creds-list">
            <li>M.Ed., [institution], [year]</li>
            <li>Dual Language Administrator Certification — [issuing body]</li>
            <li>Featured speaker, [conference name], [year]</li>
            <li>Contributor, [publication]</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Principles -->
  <section class="section-padding principles">
    <div class="container">
      <div class="section-header reveal">
        <span class="overline">How We Work</span>
        <h2>Four principles that guide every engagement</h2>
      </div>
      <div class="principles-grid">
        {principles.map((p, i) => (
          <article class="principle reveal" data-delay={i * 80}>
            <div class="icon-box" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={p.icon} />
            </div>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Affiliations -->
  <section class="section-padding affiliations">
    <div class="container">
      <div class="section-header reveal">
        <span class="overline">Rooted in Research</span>
        <h2>The research communities we draw on</h2>
      </div>
      <ul class="cred-grid reveal">
        {credentials.map(({ name, url, note }) => (
          <li>
            <a href={url} target="_blank" rel="noopener">
              <strong>{name}</strong>
              <span>{note}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <CTABand title="Let's build something lasting." body="Book a no-pressure conversation to see if we're the right fit for your district's goals." />
</BaseLayout>

<style>
  .page-header {
    padding-top: 10rem;
    padding-bottom: 3rem;
    background: var(--bg-body);
  }
  .page-header .header-content { max-width: 800px; }
  .page-header h1 {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    margin: 0.75rem 0 1.5rem;
    letter-spacing: -0.02em;
  }
  .lede {
    font-size: 1.2rem;
    color: var(--text-body);
    max-width: 680px;
  }

  .mission { background: var(--bg-surface); }
  .mission-layout {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
    align-items: start;
  }
  .mission-layout h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    letter-spacing: -0.01em;
  }
  .mission-layout p {
    font-size: 1.05rem;
    margin-bottom: 1rem;
  }

  .bio { background: var(--bg-body); }
  .bio-layout { max-width: 900px; margin: 0 auto; }
  .bio-layout h2 {
    font-size: 2rem;
    margin-bottom: 2rem;
  }
  .bio-body p { font-size: 1.05rem; margin-bottom: 1rem; }
  .bio-body ol, .bio-body ul { padding-left: 1.5rem; margin-bottom: 1rem; }
  .bio-body li { margin-bottom: 0.5rem; }
  .placeholder-note {
    background: var(--brand-gold-light);
    color: var(--brand-gold-dark);
    padding: 0.75rem 1rem;
    border-radius: var(--radius-sm);
    font-size: 0.92rem;
    border-left: 3px solid var(--brand-gold);
  }
  [data-theme="dark"] .placeholder-note {
    background: rgba(194, 157, 70, 0.1);
    color: var(--brand-gold);
  }

  .principles { background: var(--bg-surface); }
  .principles-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }
  .principle {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    padding: 2rem;
    transition: var(--transition);
  }
  .principle:hover { border-color: var(--brand-gold); transform: translateY(-3px); }
  .principle h3 { font-size: 1.2rem; margin-bottom: 0.75rem; }
  .principle p { font-size: 0.95rem; }
  .icon-box {
    width: 44px;
    height: 44px;
    background: var(--bg-surface);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--brand-gold);
    margin-bottom: 1rem;
    border: 1px solid var(--border-light);
  }

  .affiliations { background: var(--bg-body); }
  .cred-grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    max-width: 900px;
    margin: 0 auto;
  }
  .cred-grid a {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: var(--transition);
  }
  .cred-grid a:hover { border-color: var(--brand-gold); transform: translateY(-2px); }
  .cred-grid strong { color: var(--text-head); font-family: var(--font-sans); }
  .cred-grid span { color: var(--text-muted); font-size: 0.9rem; }

  @media (max-width: 900px) {
    .mission-layout { grid-template-columns: 1fr; gap: 2rem; }
    .principles-grid, .cred-grid { grid-template-columns: 1fr; }
  }
</style>
