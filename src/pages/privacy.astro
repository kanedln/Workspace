---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../site';

const updated = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title="Privacy Policy" description="Privacy policy for Immersion Education Partners." noindex>
  <section class="legal section-padding">
    <div class="container">
      <article class="legal-content">
        <span class="overline">Legal</span>
        <h1>Privacy Policy</h1>
        <p class="meta">Last updated: {updated}</p>

        <div class="placeholder-note">
          <strong>TODO before launch:</strong> Generate a policy tailored to your jurisdiction(s)
          using <a href="https://termly.io/" target="_blank" rel="noopener">Termly</a> or
          <a href="https://www.iubenda.com/" target="_blank" rel="noopener">iubenda</a> (free tiers
          work). Paste the final copy below. Required because this site uses Google Analytics
          and collects email addresses.
        </div>

        <h2>1. What we collect</h2>
        <p>
          When you submit a contact or newsletter form, we receive the name, email, organization,
          and any additional details you include. We also use Google Analytics to measure aggregate
          site usage (page views, referrers, general location).
        </p>

        <h2>2. How we use it</h2>
        <p>
          Form submissions are used solely to respond to your inquiry or send the newsletter you
          requested. Analytics data is used to understand which pages are useful and where the site
          can be improved. We do not sell or share personal data.
        </p>

        <h2>3. Cookies</h2>
        <p>
          Google Analytics sets cookies to distinguish unique visitors. You can opt out at any time
          using Google's <a href="https://tools.google.com/dlpage/gaoptout" target="_blank" rel="noopener">opt-out browser add-on</a>.
        </p>

        <h2>4. Contact</h2>
        <p>
          Questions about this policy? Email
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
        </p>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .legal { background: var(--bg-body); padding-top: 10rem; }
  .legal-content {
    max-width: 720px;
    margin: 0 auto;
  }
  .legal-content h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin: 0.75rem 0 0.5rem;
  }
  .legal-content h2 {
    font-size: 1.25rem;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .legal-content p { font-size: 1rem; margin-bottom: 1rem; }
  .legal-content a { color: var(--brand-gold); }
  .meta {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }
  .placeholder-note {
    background: var(--brand-gold-light);
    color: var(--brand-gold-dark);
    padding: 1rem 1.25rem;
    border-radius: var(--radius-sm);
    font-size: 0.92rem;
    border-left: 3px solid var(--brand-gold);
    margin: 2rem 0 3rem;
  }
  [data-theme="dark"] .placeholder-note {
    background: rgba(194, 157, 70, 0.1);
    color: var(--brand-gold);
  }
</style>
