---
const pillars = [
  {
    title: 'Evidence-Based',
    body:
      'Our methodologies are grounded in peer-reviewed research on second language acquisition, biliteracy development, and equitable program design.',
    icon: '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
  },
  {
    title: 'Customized',
    body:
      "Every district has its own demographics, goals, and constraints. We build partnerships around your context — not a template.",
    icon:
      '<circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>',
  },
  {
    title: 'Community-Rooted',
    body:
      'Families are partners, not audiences. We help you build genuine bridges between school, home, and the broader community.',
    icon:
      '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  },
];
---

<section class="section-padding expertise" id="expertise">
  <div class="container">
    <div class="section-header reveal">
      <span class="overline">Why Partner With Us</span>
      <h2>Consulting with the rigor your district deserves</h2>
    </div>

    <div class="pillars">
      {pillars.map((p, i) => (
        <article class="pillar reveal" data-delay={i * 100}>
          <div class="icon-box" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={p.icon} />
          </div>
          <h3>{p.title}</h3>
          <p>{p.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .expertise { background: var(--bg-body); }

  .pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .pillar {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    padding: 2.5rem 2rem;
    border-radius: var(--radius-md);
    transition: var(--transition);
  }

  .pillar:hover {
    transform: translateY(-4px);
    border-color: var(--brand-gold);
    box-shadow: var(--shadow-subtle);
  }

  .icon-box {
    width: 50px;
    height: 50px;
    background: var(--bg-surface);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--brand-gold);
    margin-bottom: 1.5rem;
    border: 1px solid var(--border-light);
  }

  .pillar h3 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .pillar p { font-size: 0.95rem; }

  @media (max-width: 900px) {
    .pillars { grid-template-columns: 1fr; }
  }
</style>
