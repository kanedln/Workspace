---
import { SITE } from '../site';

const year = new Date().getFullYear();
---

<footer>
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="footer-logo-wrapper">
          <img src="/images/logo.svg" alt="" class="footer-logo-img" width="48" height="48" />
          <span class="footer-logo-text">{SITE.shortName}</span>
        </div>
        <p class="footer-desc">
          Transforming education through the power of immersion and dual language strategies.
        </p>
        <address class="footer-contact">
          <a href={`mailto:${SITE.email}`}>{SITE.email}</a><br />
          <a href={`tel:${SITE.phoneRaw}`}>{SITE.phone}</a><br />
          <span>{SITE.city}, {SITE.region}</span>
        </address>
      </div>

      <div class="footer-col">
        <h4>Company</h4>
        <ul>
          <li><a href="/about">About</a></li>
          <li><a href="/about#leadership">Leadership</a></li>
          <li><a href="/contact">Contact</a></li>
          <li><a href={SITE.calendlyUrl} target="_blank" rel="noopener">Book a Call</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Resources</h4>
        <ul>
          <li><a href="https://carla.umn.edu/immersion/" target="_blank" rel="noopener">CARLA Research</a></li>
          <li><a href="https://www.cal.org/resource-center/" target="_blank" rel="noopener">CAL Resource Center</a></li>
          <li><a href="https://wida.wisc.edu/" target="_blank" rel="noopener">WIDA Consortium</a></li>
          <li><a href="https://www.actfl.org/" target="_blank" rel="noopener">ACTFL</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Stay in the loop</h4>
        <p class="footer-newsletter-copy">
          Monthly: one research summary and one implementation idea.
        </p>
        <form action={SITE.formspree.newsletter} method="POST" class="footer-newsletter">
          <label for="footer-email" class="visually-hidden">Email address</label>
          <input
            id="footer-email"
            type="email"
            name="email"
            placeholder="you@school.edu"
            required
            autocomplete="email"
          />
          <button type="submit" class="btn btn-primary" aria-label="Subscribe to newsletter">
            Subscribe
          </button>
        </form>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} {SITE.name}. All Rights Reserved.</p>
      <ul class="footer-legal">
        <li><a href="/privacy">Privacy</a></li>
        <li><a href="/terms">Terms</a></li>
      </ul>
    </div>
  </div>
</footer>

<style>
  footer {
    background: var(--bg-footer);
    color: #d1d5db;
    padding: 5rem 0 2rem;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1.3fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-brand { display: flex; flex-direction: column; gap: 1rem; }

  .footer-logo-wrapper {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-logo-img {
    height: 48px;
    width: 48px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.2);
    object-fit: cover;
    background: #fff;
  }

  .footer-logo-text {
    color: #ffffff;
    font-size: 1.5rem;
    font-weight: 800;
    font-family: var(--font-sans);
    line-height: 1;
  }

  .footer-desc {
    color: #9ca3af;
    max-width: 320px;
    font-size: 0.95rem;
  }

  .footer-contact {
    font-style: normal;
    color: #9ca3af;
    font-size: 0.9rem;
    line-height: 1.8;
  }
  .footer-contact a { color: inherit; text-decoration: none; }
  .footer-contact a:hover { color: #fff; }

  .footer-col h4 {
    color: #ffffff;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1.25rem;
  }

  .footer-col ul { list-style: none; }
  .footer-col li { margin-bottom: 0.75rem; }

  .footer-col a {
    color: #9ca3af;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.3s;
  }
  .footer-col a:hover { color: #ffffff; }

  .footer-newsletter-copy {
    color: #9ca3af;
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .footer-newsletter {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .footer-newsletter input {
    padding: 0.75rem 1rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.05);
    color: #ffffff;
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 0.9rem;
  }
  .footer-newsletter input::placeholder { color: #6b7280; }
  .footer-newsletter input:focus {
    outline: none;
    border-color: var(--brand-gold);
  }
  .footer-newsletter button { width: 100%; }

  .footer-bottom {
    padding-top: 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    color: #6b7280;
    font-size: 0.85rem;
  }

  .footer-legal {
    list-style: none;
    display: flex;
    gap: 1.5rem;
  }
  .footer-legal a {
    color: #6b7280;
    text-decoration: none;
    transition: color 0.3s;
  }
  .footer-legal a:hover { color: #fff; }

  .visually-hidden {
    position: absolute !important;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }

  @media (max-width: 1024px) {
    .footer-top { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
  }

  @media (max-width: 600px) {
    .footer-top { grid-template-columns: 1fr; }
    .footer-bottom { justify-content: center; text-align: center; }
  }
</style>
