---
const services = [
  {
    title: 'Program Design',
    blurb:
      'Launching a dual language or immersion program requires precision. We guide you through needs assessment, language allocation, and staffing strategy so your launch is built for the long haul.',
    features: [
      'Community needs assessment',
      'Language allocation modeling (50/50, 90/10, and beyond)',
      'Staffing and recruitment strategy',
      'Multi-year implementation roadmap',
    ],
    icon: 'compass',
  },
  {
    title: 'Professional Development',
    blurb:
      'Research-backed, classroom-tested workshops that equip teachers and coaches with strategies they can use Monday morning — not just at the next in-service.',
    features: [
      'Biliteracy curriculum design',
      'Cross-linguistic transfer strategies',
      'Sheltered instruction and scaffolding',
      'Culturally sustaining pedagogy',
    ],
    icon: 'book-open',
  },
  {
    title: 'Instructional Coaching',
    blurb:
      'Embedded coaching cycles that build teacher agency. We partner with your leaders on walkthroughs, co-planning, and data-informed feedback loops.',
    features: [
      'Classroom walkthroughs with feedback',
      'Co-planning and co-teaching cycles',
      'Grade-level and PLC facilitation',
      'Teacher leader pipelines',
    ],
    icon: 'users',
  },
  {
    title: 'Assessment & Evaluation',
    blurb:
      'Program health checks and biliteracy assessments that go beyond compliance — so you can show families, boards, and funders the real story of student growth.',
    features: [
      'Biliteracy growth audits',
      'Program fidelity reviews',
      'Board-ready reporting and dashboards',
      'Equity and access analysis',
    ],
    icon: 'bar-chart',
  },
];

const iconMap: Record<string, string> = {
  compass:
    '<circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>',
  'book-open':
    '<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
  users:
    '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  'bar-chart':
    '<line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/>',
};
---

<section class="section-padding services" id="services">
  <div class="container">
    <div class="section-header reveal">
      <span class="overline">What We Do</span>
      <h2>Comprehensive consulting, built for districts</h2>
      <p class="section-sub">
        Four practice areas that together span the full lifecycle of an immersion program.
      </p>
    </div>

    <div class="services-grid">
      {services.map((svc, i) => (
        <article class="service-card reveal" data-delay={i * 80}>
          <div class="icon-box" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={iconMap[svc.icon]} />
          </div>
          <h3>{svc.title}</h3>
          <p>{svc.blurb}</p>
          <ul class="feature-list">
            {svc.features.map((f) => (
              <li>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                <span>{f}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .services { background: var(--bg-surface); }

  .section-sub {
    font-size: 1.1rem;
    color: var(--text-body);
    margin-top: 0.5rem;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .service-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    padding: 2.5rem;
    border-radius: var(--radius-md);
    transition: var(--transition);
  }

  .service-card:hover {
    transform: translateY(-4px);
    border-color: var(--brand-gold);
    box-shadow: var(--shadow-float);
  }

  .icon-box {
    width: 52px;
    height: 52px;
    background: var(--bg-surface);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--brand-gold);
    margin-bottom: 1.5rem;
    border: 1px solid var(--border-light);
  }

  .service-card h3 {
    font-size: 1.4rem;
    margin-bottom: 0.75rem;
  }

  .service-card p {
    font-size: 0.98rem;
    margin-bottom: 1.25rem;
  }

  .feature-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .feature-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    color: var(--text-body);
    font-size: 0.92rem;
  }

  .feature-list svg {
    color: var(--brand-gold);
    margin-top: 3px;
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .services-grid { grid-template-columns: 1fr; }
    .service-card { padding: 2rem; }
  }
</style>
