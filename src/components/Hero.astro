---
import { SITE } from '../site';
---

<section class="hero">
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="container">
    <div class="hero-content">
      <div class="hero-text reveal">
        <span class="overline">Educational Consulting</span>
        <h1>Transforming Education Through Immersion.</h1>
        <p>
          We partner with districts to design, launch, and sustain world-class dual language and
          immersion programs where every learner thrives.
        </p>
        <div class="hero-btns">
          <a href="/contact" class="btn btn-primary">Book a Consultation</a>
          <a href="/#services" class="btn btn-outline">Explore Services</a>
        </div>
        <ul class="hero-trust">
          <li>Research-based methodology</li>
          <li>Milwaukee-rooted, nationally engaged</li>
          <li>Led by practicing educators</li>
        </ul>
      </div>
      <div class="hero-image-wrapper reveal" data-delay="150">
        <img
          src="/images/hero.svg"
          alt="Classroom immersion program in action"
          class="hero-image"
          width="720"
          height="540"
          fetchpriority="high"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 92vh;
    display: flex;
    align-items: center;
    padding-top: 6rem;
    padding-bottom: 4rem;
    background: var(--bg-body);
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background:
      radial-gradient(ellipse 50% 40% at 20% 30%, rgba(194, 157, 70, 0.10), transparent 60%),
      radial-gradient(ellipse 50% 50% at 85% 70%, rgba(194, 157, 70, 0.06), transparent 60%);
  }

  [data-theme="dark"] .hero-bg {
    background:
      radial-gradient(ellipse 50% 40% at 20% 30%, rgba(194, 157, 70, 0.14), transparent 60%),
      radial-gradient(ellipse 50% 50% at 85% 70%, rgba(194, 157, 70, 0.08), transparent 60%);
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 5rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-text h1 {
    font-size: clamp(2.5rem, 5vw, 4.25rem);
    font-weight: 800;
    line-height: 1.08;
    margin: 0.75rem 0 1.5rem;
    font-family: var(--font-sans);
    letter-spacing: -0.02em;
  }

  .hero-text p {
    font-size: 1.2rem;
    margin-bottom: 2rem;
    max-width: 540px;
    color: var(--text-body);
  }

  .hero-btns {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
    margin-bottom: 2.5rem;
  }

  .hero-trust {
    list-style: none;
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border-light);
  }
  .hero-trust li {
    position: relative;
    padding-left: 1.25rem;
    font-size: 0.9rem;
    color: var(--text-body);
  }
  .hero-trust li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--brand-gold);
  }

  .hero-image-wrapper {
    position: relative;
  }

  .hero-image {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-float);
    padding: 10px;
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  .hero-image-wrapper::before {
    content: '';
    position: absolute;
    top: -20px;
    right: -20px;
    width: 100%;
    height: 100%;
    border: 1px solid var(--brand-gold);
    border-radius: var(--radius-lg);
    z-index: -1;
    opacity: 0.4;
  }

  @media (max-width: 1024px) {
    .hero { min-height: auto; }
    .hero-content { grid-template-columns: 1fr; gap: 3rem; }
    .hero-image-wrapper { order: -1; max-width: 500px; margin: 0 auto; }
    .hero-image-wrapper::before { display: none; }
  }

  @media (max-width: 600px) {
    .hero-trust { gap: 0.75rem 1.5rem; }
  }
</style>
