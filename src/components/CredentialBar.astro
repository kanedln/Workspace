---
// Replaces the fake "District One" partners with real credential/association references.
// Until logo files are provided, show names + a unifying icon mark.
const credentials = [
  { name: 'WIDA Consortium', url: 'https://wida.wisc.edu/' },
  { name: 'ACTFL', url: 'https://www.actfl.org/' },
  { name: 'CARLA', url: 'https://carla.umn.edu/' },
  { name: 'Center for Applied Linguistics', url: 'https://www.cal.org/' },
];
---

<section class="credentials">
  <div class="container">
    <p class="credentials-title">Grounded in the national research community</p>
    <ul class="credentials-grid">
      {credentials.map(({ name, url }) => (
        <li>
          <a href={url} target="_blank" rel="noopener" aria-label={`Learn more about ${name}`}>
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
            <span>{name}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .credentials {
    padding: 3rem 0;
    background: var(--bg-surface);
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
  }

  .credentials-title {
    text-align: center;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
    font-weight: 600;
  }

  .credentials-grid {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
    list-style: none;
  }

  .credentials-grid a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-body);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    opacity: 0.8;
    transition: opacity 0.3s, color 0.3s;
  }
  .credentials-grid a:hover { opacity: 1; color: var(--brand-gold); }
  .credentials-grid svg { color: var(--brand-gold); flex-shrink: 0; }

  @media (max-width: 700px) {
    .credentials-grid { gap: 1.5rem; }
    .credentials-grid a { font-size: 0.85rem; }
  }
</style>
