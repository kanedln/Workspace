---
// Real testimonials — you confirmed you have these with permission.
// Fill in actual quotes + attribution before launch; the placeholders below
// are clearly labeled so you can't accidentally ship them.
const testimonials = [
  {
    quote:
      '[PLACEHOLDER — replace with a real quote you have permission to publish. Aim for a concrete outcome, not just praise.]',
    name: '[First Name Last Initial]',
    role: '[Role]',
    org: '[District or Organization]',
  },
  {
    quote:
      '[PLACEHOLDER — second quote. Different voice (admin vs. teacher vs. coach) strengthens the section.]',
    name: '[First Name Last Initial]',
    role: '[Role]',
    org: '[District or Organization]',
  },
];
---

<section class="section-padding testimonials">
  <div class="container">
    <div class="section-header reveal">
      <span class="overline">Voices from the field</span>
      <h2>What educators say</h2>
    </div>
    <div class="testimonial-grid">
      {testimonials.map((t, i) => (
        <figure class="testimonial-card reveal" data-delay={i * 120}>
          <div class="stars" aria-label="5 out of 5 stars">
            {[0, 1, 2, 3, 4].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="0" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            ))}
          </div>
          <blockquote>
            <p>{t.quote}</p>
          </blockquote>
          <figcaption>
            <strong>{t.name}</strong>
            <span>{t.role}, {t.org}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials { background: var(--bg-surface); }

  .testimonial-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .testimonial-card {
    background: var(--bg-card);
    padding: 2.5rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--border-light);
    margin: 0;
    transition: var(--transition);
  }

  .testimonial-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-float);
  }

  .stars {
    color: var(--brand-gold);
    display: flex;
    gap: 3px;
    margin-bottom: 1.25rem;
  }

  blockquote p {
    font-size: 1.1rem;
    font-style: italic;
    color: var(--text-head);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  figcaption {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-light);
  }
  figcaption strong {
    color: var(--text-head);
    font-family: var(--font-sans);
    font-size: 1rem;
  }
  figcaption span {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  @media (max-width: 900px) {
    .testimonial-grid { grid-template-columns: 1fr; }
  }
</style>
